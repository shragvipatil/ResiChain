# ── LLM ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── External Data APIs ────────────────────────────
EIA_API_KEY=your_eia_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
AISHUB_USERNAME=your_aishub_username_here
AISHUB_API_KEY=your_aishub_api_key_here
RELIEFWEB_APP_NAME=resichain-hackathon

# ── Notifications ─────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
ALERT_EMAIL_ADDRESS=your_team_email_here
ALERT_EMAIL_PASSWORD=your_gmail_app_password_here

# ── Databases ─────────────────────────────────────
POSTGRES_USER=resichain
POSTGRES_PASSWORD=choose_a_strong_password
POSTGRES_DB=resichain_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://resichain:choose_a_strong_password@postgres:5432/resichain_db

NEO4J_AUTH=neo4j/choose_a_strong_password
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=choose_a_strong_password

REDIS_URL=redis://redis:6379/0

CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── Application ───────────────────────────────────
JWT_SECRET_KEY=generate_a_long_random_string_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── Agent Configuration ───────────────────────────
GDELT_POLL_INTERVAL_SECONDS=300
RISK_THRESHOLD_CRISIS=0.65
MAX_SUPPLIER_SHARE_PCT=0.40
SPR_RESERVE_FLOOR_PCT=0.40
SPR_MAX_DAILY_RELEASE_MBD=0.5
DEMO_MODE=false